---
---

<div class="row">
  {% if site.enable_publication_thumbnails %}
  <div class="col col-sm-2 abbr">
    {% if entry.abbr %}
      <abbr class="badge rounded w-100">{{ entry.abbr }}</abbr>
    {% endif %}

    {% if entry.preview %}
      {% if entry.preview contains '://' %}
        <img class="preview z-depth-1 rounded" src="{{ entry.preview }}">
      {% else %}
        {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
        {% include figure.liquid path=entry_path sizes="200px" class="preview z-depth-1 rounded" zoomable=true avoid_scaling=true %}
      {% endif %}
    {% endif %}
  </div>
  {% endif %}

  <div class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">

    <!-- Title -->
    <div class="title" style="font-weight: bold; font-size: 1.1em;">
      {% if entry.url %}
        <a href="{{ entry.url }}" target="_blank">{{ entry.title }}</a>
      {% else %}
        {{ entry.title }}
      {% endif %}
    </div>

    <!-- Authors -->
    <div class="author">
      {% for author in entry.author_array %}
        {% assign last = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' %}
        {{ author.first }} {{ last }}{% unless forloop.last %}, {% endunless %}
      {% endfor %}
    </div>

    <!-- Venue + Year -->
    {% if entry.journal %}
      <div class="periodical" style="font-style: italic; color: #555;">
        {{ entry.journal }}, {{ entry.year }}
      </div>
    {% elsif entry.booktitle %}
      <div class="periodical" style="font-style: italic; color: #555;">
        In {{ entry.booktitle }}, {{ entry.year }}
      </div>
    {% endif %}

    <!-- Links (Scholar style) -->
    <div class="links" style="margin-top: 5px;">
      {% if entry.pdf %}
        <a href="{{ entry.pdf }}" target="_blank">[PDF]</a>
      {% endif %}
      {% if entry.doi %}
        <a href="https://doi.org/{{ entry.doi }}" target="_blank">[DOI]</a>
      {% endif %}
      {% if entry.code %}
        <a href="{{ entry.code }}" target="_blank">[Code]</a>
      {% endif %}
      {% if entry.website %}
        <a href="{{ entry.website }}" target="_blank">[Link]</a>
      {% endif %}
      {% if entry.arxiv %}
        <a href="https://arxiv.org/abs/{{ entry.arxiv }}" target="_blank">[arXiv]</a>
      {% endif %}
    </div>

  </div>
</div>